{
  "version": "4.2.0",
  "name": "Security Hardening, Endpoint Permissions, and Access Review",
  "layer": "security_access_review",
  "shortcodes": [
    "[sc_research_librarian mode=\"security-summary\"]",
    "[sc_research_librarian_security_summary]"
  ],
  "endpoints": [
    "GET /wp-json/sc-research-librarian-ai/v1/security/status",
    "GET /wp-json/sc-research-librarian-ai/v1/security/endpoints",
    "POST /wp-json/sc-research-librarian-ai/v1/security/run-audit",
    "GET /wp-json/sc-research-librarian-ai/v1/security/export"
  ],
  "checks": [
    "admin_exports_protected",
    "secret_fingerprints_only",
    "knowledge_index_present",
    "gemini_key_fingerprint_present",
    "question_redaction_enabled",
    "retention_reasonable",
    "public_endpoint_boundary"
  ],
  "admin_only_payloads": [
    "raw logs",
    "exports",
    "snapshots",
    "restore actions",
    "embedding diagnostics"
  ],
  "public_safe_payloads": [
    "status summaries",
    "readiness summaries",
    "security posture summary"
  ]
}
