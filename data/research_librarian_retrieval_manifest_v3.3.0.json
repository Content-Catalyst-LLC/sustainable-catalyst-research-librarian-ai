{
  "version": "3.3.0",
  "name": "Gemini Retrieval Backend with Embeddings",
  "provider": "gemini",
  "default_embedding_model": "gemini-embedding-001",
  "retrieval_modes": [
    "keyword-source",
    "hybrid-gemini-embedding"
  ],
  "endpoints": [
    "/retrieval/status",
    "/retrieval/query",
    "/index/embed"
  ],
  "shortcodes": [
    "[sc_research_librarian mode=\"retrieval-status\"]"
  ]
}