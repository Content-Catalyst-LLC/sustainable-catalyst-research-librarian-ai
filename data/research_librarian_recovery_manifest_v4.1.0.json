{
  "version": "4.1.0",
  "release": "Index Snapshots, Backup, Restore, and Migration Readiness",
  "capabilities": [
    "admin recovery snapshots",
    "knowledge index backup without embedding vectors",
    "embedding status backup",
    "evaluation status backup",
    "handoff status backup",
    "governance status backup",
    "maintenance status backup",
    "admin recovery export",
    "dry-run restore planning",
    "public-safe recovery summary"
  ],
  "endpoints": [
    "/recovery/status",
    "/recovery/create",
    "/recovery/export",
    "/recovery/restore",
    "/recovery/delete"
  ],
  "shortcodes": [
    "[sc_research_librarian mode=\"recovery-summary\" title=\"Research Librarian Recovery Readiness\"]",
    "[sc_research_librarian_recovery_summary title=\"Research Librarian Recovery Readiness\"]"
  ],
  "recovery_policy": {
    "snapshot_limit": 10,
    "restore_default_mode": "dry_run",
    "admin_only_restore": true,
    "embedding_vectors_in_snapshots": false,
    "post_restore_required_action": "Regenerate Gemini embeddings after restoring a snapshot."
  }
}
