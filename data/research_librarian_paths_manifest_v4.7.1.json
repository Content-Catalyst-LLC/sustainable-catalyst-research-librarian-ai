{
  "version": "4.7.1",
  "release": "v4.7.1 \u2014 Guided Research Paths and Multi-Step Route Builder, rebased on Public Answer UX",
  "features": [
    "Guided research path templates",
    "Multi-step route builder endpoint",
    "Path confidence scoring",
    "Quick/standard/deep path depths",
    "Path session save/log/export",
    "Public path builder shortcode",
    "Admin Guided Paths dashboard",
    "Boundary-aware checkpoints and handoff targets"
  ],
  "public_endpoints": [
    "/paths/status",
    "/paths/catalog",
    "/paths/build",
    "/paths/save"
  ],
  "admin_endpoints": [
    "/paths/logs",
    "/paths/export",
    "/paths/reset-defaults"
  ],
  "shortcodes": [
    "[sc_research_librarian mode=\"guided-paths\"]",
    "[sc_research_librarian mode=\"path-builder\"]",
    "[sc_research_librarian_paths_summary]",
    "[sc_research_librarian_path_builder]"
  ]
}