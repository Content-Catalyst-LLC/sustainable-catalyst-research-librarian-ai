    "automatic_destination_execution": false,
    "integration_key_required": true,
    "wordpress_nonce_required": true,
    "tokens_excluded_from_admin_export": true
  },
  "compatibility": {
    "additive_sqlite_migration": true,
    "paid_vector_database_required": false,
    "persistent_render_disk_required": false,
    "black_green_prompt_preserved": true,
    "light_evidence_cards_preserved": true
  }
