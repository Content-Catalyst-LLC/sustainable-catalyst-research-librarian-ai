{
  "schema": "sc-research-librarian-release-manifest/1.0",
  "version": "6.6.1",
  "release": "Cross-Product Reliability Patch",
  "sqlite_schema_version": 8,
  "contracts": {
    "capabilities": "sc-platform-capabilities/1.1",
    "compatibility": "sc-platform-compatibility/1.0",
    "handoff": "sc-research-handoff/2.0",
    "route": "sc-research-route/2.0",
    "delivery": "sc-research-handoff-delivery/1.0",
    "receipt": "sc-research-handoff-receipt/1.0",
    "artifact_return": "sc-research-artifact-return/1.0"
  },
  "minimum_destination_versions": {
    "workbench": "4.0.0",
    "decision_studio": "1.0.0",
    "site_intelligence": "2.0.0",
    "lab": "0.6.0",
    "feature_suggestions": "3.0.0"
  },
  "reliability": {
    "bounded_retry": true,
    "exponential_backoff_metadata": true,
